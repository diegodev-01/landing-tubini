---
import Header from '@components/ui/Header.astro';
import Layout from '@layouts/Layout.astro';
import Hero from '@components/sections/Hero.astro';
import AnnouncementBar from '@components/ui/AnnouncementBar.astro';
import ClientReviews from '@/components/sections/clients-reviews/ClientReviews.astro';
import Footer from '@/components/ui/Footer.astro';
import CommonQuestions from '@/components/sections/common-questions/CommonQuestions.astro';

const reviews = [
  {
    rating: 5,
    title: 'Asesores de confianza',
    comment:
      'Nuestra experiencia con Tubini fue excepcional. La dedicación y profesionalismo de su equipo hicieron que encontrar la casa de nuestros sueños fuera pan comido. ¡Altamente recomendados!',
    name: 'Juan Pérez',
    role: 'Cliente',
  },
  {
    rating: 5,
    title: 'Servicio excepcional',
    comment:
      'Tubini nos brindó un servicio de primera. Nos ayudaron a vender nuestra propiedad rápidamente y a un precio excelente. Estamos sumamente satisfechos con el resultado.',
    name: 'María Gómez',
    role: 'Cliente',
  },
  {
    rating: 5,
    title: 'Eficiente y confiable',
    comment:
      'El equipo de Tubini nos guió durante todo el proceso de compra. Su conocimiento y dedicación a nuestras necesidades fueron impresionantes. ¡Gracias por su apoyo!',
    name: 'Carlos Rodríguez',
    role: 'Cliente',
  },
];

const questions = [
  {
    question: '¿Cuánto se paga de comisión?',
    answer:
      'En Tubini ofrecemos una de las comisiones más competitivas del mercado.\n* Ventas: entre 2% y 3%\n* Alquileres: solo el 30% de un mes de alquiler',
  },
  {
    question: '¿Qué servicios ofrece Tubini?',
    answer:
      'Ofrecemos servicios de compra, venta y alquiler de propiedades, así como asesoramiento personalizado para ayudarte a tomar decisiones informadas.',
  },
  {
    question: '¿Cómo puedo contactar a un agente inmobiliario?',
    answer:
      'Puedes contactarnos a través de nuestro formulario en línea, por teléfono o visitando nuestras oficinas. Nuestro equipo estará encantado de ayudarte.',
  },
];
---

<Layout>
  <AnnouncementBar />
  <Header />
  <Hero />
  <ClientReviews reviews={reviews} />
  <CommonQuestions questions={questions} />
  <Footer />
</Layout>
