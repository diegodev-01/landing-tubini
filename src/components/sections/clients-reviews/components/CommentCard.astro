---
const { title, rating, comment, name, role } = Astro.props;
---

<article class="comment-card">
  <h3 class="title">{title}</h3>
  <div class="rating">
    {
      Array.from({ length: 5 }, (_, i) => (
        <span class={i < rating ? 'star filled' : 'star'}>★</span>
      ))
    }
  </div>
  <p class="comment">{comment}</p>
  <div class="author">
    <h4 class="name">{name}</h4>
    <p class="role">{role}</p>
  </div>
</article>
<style>
  .comment-card {
    background-color: var(--dark-color);
    border: 1px solid var(--gray-color-15);
    padding: 20px;
    border-radius: 10px;
    max-width: 400px;
  }

  .rating {
    display: flex;
    gap: 4px;
    margin-bottom: 8px;
  }

  .star {
    font-size: 20px;
    color: var(--gray-color-60);
  }

  .star.filled {
    color: var(--stars-color);
  }

  .title {
    font-size: 1.2em;
    margin-bottom: 8px;
    color: var(--text-color);
  }

  .comment {
    font-size: 1em;
    margin-bottom: 12px;
    color: var(--text-color);
  }

  .author {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .name {
    font-size: 1.1em;
    font-weight: bold;
    margin: 0;
    color: var(--text-color);
  }

  .role {
    font-size: 0.9em;
    color: var(--gray-color-60);
  }
</style>
